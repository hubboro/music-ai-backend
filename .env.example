# OpenAI
OPENAI_API_KEY=your_openai_api_key

# Spotify OAuth (from developer.spotify.com)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=https://your-backend.onrender.com/callback

# Spotify account used to create guest playlists
APP_SPOTIFY_REFRESH_TOKEN=

# Optional persistent share pages
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional Supabase maintenance heartbeat for Render Cron
HEARTBEAT_MAX_RANDOM_DELAY_SECONDS=600
HEARTBEAT_SOURCE=render-cron

# Cost and abuse controls (defaults shown)
GENERATE_PER_HOUR=5
GLOBAL_GENERATE_PER_DAY=50
SPOTIFY_PLAYLISTS_PER_HOUR=5
GLOBAL_SPOTIFY_PLAYLISTS_PER_DAY=100
SOUNDTRACK_WRITES_PER_HOUR=15
GLOBAL_SOUNDTRACK_WRITES_PER_DAY=300
SOUNDTRACK_READS_PER_HOUR=120
GENERATION_CONCURRENCY=2
MAX_REQUEST_BYTES=32768
PLAYLIST_CACHE_TTL_SECONDS=86400
PLAYLIST_CACHE_MAX_ENTRIES=200
MAX_PLAYLIST_REPAIR_ATTEMPTS=1
PLAYLIST_ENGINE_VERSION=v1
PLAYLIST_ENGINE_SHADOW=false
PLAYLIST_V2_CANDIDATE_COUNT=40
PLAYLIST_V2_MIN_VALIDATED_TRACKS=14
PLAYLIST_V2_MODEL=gpt-4.1-mini
PLAYLIST_V2_OPENAI_TIMEOUT_SECONDS=20
PLAYLIST_V2_SHADOW_TIMEOUT_SECONDS=45
SPOTIFY_SEARCH_TIMEOUT_SECONDS=6
